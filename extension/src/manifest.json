{
  "manifest_version": 3,
  "permissions": [
    "alarms",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "@scalpel"
    }
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Scalpel"
  },
  "background": {
    "scripts": [
      "src/background.ts"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
